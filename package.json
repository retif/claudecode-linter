{
	"name": "claudecode-linter",
	"version": "2.1.69",
	"description": "Standalone linter for Claude Code plugin artifacts",
	"type": "module",
	"bin": {
		"claudecode-linter": "dist/index.js"
	},
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build",
		"deps:check": "ncu",
		"deps:update": "ncu -u",
		"knip": "knip --exclude types",
		"extract-contracts": "tsx scripts/extract-contracts.ts",
		"generate-contracts": "tsx scripts/generate-contracts.ts"
	},
	"files": [
		"dist/",
		".claudecode-lint.defaults.yaml",
		"README.md"
	],
	"keywords": [
		"claude-code",
		"plugin",
		"linter",
		"fixer",
		"cli"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"glob": "^13.0.6",
		"minimatch": "^10.2.4",
		"prettier": "^3.8.1",
		"semver": "^7.7.4",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"@types/semver": "^7.7.1",
		"acorn": "^8.16.0",
		"acorn-walk": "^8.3.5",
		"knip": "^5.85.0",
		"npm-check-updates": "^19.6.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "4.0.18"
	}
}
