{
	"name": "claudecode-linter",
	"version": "2.1.87",
	"description": "Standalone linter for Claude Code plugins and configuration files",
	"type": "module",
	"bin": {
		"claudecode-linter": "dist/index.js"
	},
	"exports": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build",
		"deps:check": "ncu",
		"deps:update": "ncu -u",
		"knip": "knip --exclude types",
		"check-deps": "tsx scripts/check-deps.ts",
		"extract-contracts": "tsx scripts/extract-contracts.ts",
		"generate-contracts": "tsx scripts/generate-contracts.ts"
	},
	"files": [
		"dist/**/*.js",
		".claudecode-lint.defaults.yaml",
		"README.md"
	],
	"keywords": [
		"claude-code",
		"plugin",
		"linter",
		"fixer",
		"cli"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/retif/claudecode-linter.git"
	},
	"homepage": "https://github.com/retif/claudecode-linter#readme",
	"bugs": {
		"url": "https://github.com/retif/claudecode-linter/issues"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"minimatch": "^10.2.4",
		"picocolors": "^1.1.1",
		"prettier": "^3.8.1",
		"semver": "^7.7.4",
		"tinyglobby": "^0.2.15",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@types/node": "^25.3.3",
		"@types/semver": "^7.7.1",
		"acorn": "^8.16.0",
		"acorn-walk": "^8.3.5",
		"knip": "^6.0.5",
		"npm-check-updates": "^19.6.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "4.1.0"
	}
}
