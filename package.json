{
  "name": "@retif/claude-lint",
  "version": "0.1.0",
  "description": "Standalone linter for Claude Code plugin artifacts",
  "type": "module",
  "bin": {
    "claude-lint": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    ".claude-lint.defaults.yaml",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "plugin",
    "linter",
    "fixer",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "prettier": "^3.8.1",
    "semver": "^7.6.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.5.0",
    "typescript": "^5.4.0",
    "vitest": "1.6.0"
  }
}
